# Postgres
DATABASE_URL=postgresql://finlink:finlink@postgres:5432/finlink
TEST_DATABASE_URL=postgresql://finlink:finlink@postgres-test:5432/finlink_test

# Redis
REDIS_URL=redis://redis:6379

# Secrets (generate with: openssl rand -hex 32)
JWT_SECRET=change_me_jwt_secret_change_me_jwt_secret_
LINK_TOKEN_SECRET=change_me_link_secret_change_me_link_secret
WEBHOOK_SIGNING_SECRET=change_me_webhook_secret_change_me_webhook

# Optional: Alpha Vantage API key for real stock price refresh
ALPHA_VANTAGE_API_KEY=

# SnapTrade — real brokerage data aggregation
# Sign up free at https://dashboard.snaptrade.com/signup (no credit card).
# Free tier = 5 brokerage connections per user, unlimited time.
# Leave empty to disable real-brokerage mode (demo account always works regardless).
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
# Optional — only needed if you want webhook-driven syncs (use ngrok for local dev).
SNAPTRADE_WEBHOOK_SECRET=

# Ports / URLs
PORT=3001
DASHBOARD_URL=http://localhost:5174
LINK_UI_URL=http://localhost:5175
CORS_ORIGINS=http://localhost:5174,http://localhost:5175

# Environment mode (sandbox | development | production)
ENVIRONMENT=sandbox
