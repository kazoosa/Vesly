# Production env template — paste these into Koyeb's "Secrets" UI.
# (For Vercel frontends, set VITE_API_URL and VITE_LINK_UI_URL in each project's env vars.)

# Postgres — from Neon (Step 2 in the deploy checklist)
DATABASE_URL=postgresql://neondb_owner:xxx@ep-xyz.us-east-2.aws.neon.tech/neondb?sslmode=require

# Redis — from Upstash (Step 3). Use the ioredis-format URL (not the REST one).
REDIS_URL=rediss://default:xxx@us1-xxx.upstash.io:6380

# Secrets — generate fresh ones: `openssl rand -hex 32`
JWT_SECRET=CHANGE_ME
LINK_TOKEN_SECRET=CHANGE_ME
WEBHOOK_SIGNING_SECRET=CHANGE_ME

# CORS — comma-separated list of the Vercel URLs that are allowed to call the API.
# Put BOTH dashboard and link-ui URLs here. Also add any custom domain you set up.
CORS_ORIGINS=https://all-account-stocks-dashboard.vercel.app,https://all-account-stocks-link-ui.vercel.app

# Public URLs — used by the backend to generate redirect URIs + CORS lookups
DASHBOARD_URL=https://all-account-stocks-dashboard.vercel.app
LINK_UI_URL=https://all-account-stocks-link-ui.vercel.app

# Environment mode
ENVIRONMENT=production
NODE_ENV=production
PORT=3001

# SnapTrade (optional — only needed if you want real brokerage data for non-demo users)
SNAPTRADE_CLIENT_ID=
SNAPTRADE_CONSUMER_KEY=
SNAPTRADE_WEBHOOK_SECRET=
